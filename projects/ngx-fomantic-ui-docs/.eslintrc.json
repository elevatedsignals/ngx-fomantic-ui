{
  "extends": "../../.eslintrc.json",
  "ignorePatterns": [
    "!**/*"
  ],
  "overrides": [
    // Rule overrides rationale (ESLint loads .eslintrc.json with JSONC, comments allowed):
    //
    // Rules kept "off" with reasoning:
    //   @angular-eslint/component-selector:
    //     Docs demo pages use selectors like 'demo-page-transition' rather than
    //     the 'app-' prefix; matching the convention is not worth refactoring
    //     inline demo components.
    //   @angular-eslint/component-class-suffix:
    //     Inline demo components are named *Page, *Example, etc., not
    //     *Component. Out of scope to rename.
    //   @angular-eslint/directive-class-suffix:
    //     Same as component-class-suffix.
    //   @angular-eslint/template/no-autofocus:
    //     The alert/confirm demo modals intentionally autofocus the OK button;
    //     the auto-fix removes that behavior.
    //   @angular-eslint/prefer-standalone:
    //     Docs app uses NgModule-based bootstrapping; matches the library it
    //     showcases. Migrating to standalone is out of scope for the v19
    //     upgrade.
    //   @typescript-eslint/no-explicit-any, no-empty-function, ban-types,
    //   no-inferrable-types:
    //     Not enforced by the original tslint baseline; not worth chasing in
    //     demo code that has accumulated drift while lint was broken.
    //   @typescript-eslint/no-unsafe-function-type:
    //     New in @typescript-eslint v8 (split out of the legacy ban-types rule).
    //     Disabled here for symmetry with the library config; the docs app
    //     currently has no violations but inheriting the same baseline avoids
    //     surprise if a future demo page uses a bare `Function` type.
    //   @angular-eslint/template/click-events-have-key-events,
    //   interactive-supports-focus, mouse-events-have-key-events,
    //   label-has-associated-control, alt-text:
    //     Accessibility improvements to demo pages are out of scope.
    {
      "files": [
        "*.ts"
      ],
      "rules": {
        "@angular-eslint/directive-selector": [
          "error",
          {
            "type": "attribute",
            "prefix": "app",
            "style": "camelCase"
          }
        ],
        "@angular-eslint/component-selector": "off",
        "@angular-eslint/component-class-suffix": "off",
        "@angular-eslint/directive-class-suffix": "off",
        "@angular-eslint/no-output-on-prefix": "warn",
        "@angular-eslint/prefer-standalone": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-empty-function": "off",
        "@typescript-eslint/ban-types": "off",
        "@typescript-eslint/no-unsafe-function-type": "off",
        "@typescript-eslint/no-inferrable-types": "off",
        "@typescript-eslint/no-non-null-assertion": "warn",
        "@typescript-eslint/no-unused-vars": "warn",
        "quotes": [
          "warn",
          "single",
          {
            "allowTemplateLiterals": true
          }
        ],
        "@typescript-eslint/member-ordering": [
          "warn",
          {
            "default": [
              "static-field",
              "instance-field",
              "static-method",
              "instance-method"
            ]
          }
        ],
        "max-len": [
          "warn",
          {
            "code": 140,
            "ignoreUrls": true,
            "ignoreStrings": true,
            "ignoreTemplateLiterals": true
          }
        ],
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "rxjs/Rx",
                "message": "Import from 'rxjs' or specific submodules instead."
              }
            ]
          }
        ],
        "curly": [
          "warn",
          "all"
        ],
        "no-console": [
          "warn",
          {
            "allow": [
              "warn",
              "error",
              "log"
            ]
          }
        ]
      }
    },
    {
      "files": [
        "*.html"
      ],
      "rules": {
        "@angular-eslint/template/click-events-have-key-events": "off",
        "@angular-eslint/template/interactive-supports-focus": "off",
        "@angular-eslint/template/mouse-events-have-key-events": "off",
        "@angular-eslint/template/label-has-associated-control": "off",
        "@angular-eslint/template/alt-text": "off",
        "@angular-eslint/template/no-autofocus": "off",
        "@angular-eslint/template/eqeqeq": "warn"
      }
    }
  ]
}
